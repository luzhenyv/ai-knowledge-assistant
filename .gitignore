# --- Confidential / internal material — never commit ---
# Raw source documents in any format.
*.pages
*.docx
*.pdf
# Ignore ALL knowledge docs by default; only the synthetic sample is shared.
# Drop your real internal SOPs anywhere under docs/ and they stay private.
docs/*
!docs/sample-field-app
# Per-material preprocessing profiles may name internal material; keep them
# private and share only the sample.
profiles/*
!profiles/sample.yaml
# Build artifacts (generated by `aka build`) and preprocessing intermediates.
var/

# Python
__pycache__/
*.pyc
.venv/
.venv-test/
*.egg-info/
.pytest_cache/

# Model / embedding caches
.cache/

# macOS
.DS_Store
